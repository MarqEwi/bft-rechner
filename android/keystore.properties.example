# Vorlage für die Release-Signierung.
# 1. Diese Datei kopieren und in "keystore.properties" umbenennen (ohne .example).
# 2. Werte unten anpassen. Diese Datei wird NICHT ins Git hochgeladen.
#
# storeFile = Pfad zu deinem Keystore. Am einfachsten: die Datei android.keystore
#            in diesen android/-Ordner kopieren, dann reicht der Name "android.keystore".
#            (Du kannst auch den vollen Windows-Pfad angeben, z. B.
#             C:\\Users\\marce\\spaz-twa\\android.keystore  -> Backslashes doppelt!)

storeFile=android.keystore
storePassword=DEIN_KEYSTORE_PASSWORT
keyAlias=DEIN_ALIAS
keyPassword=DEIN_KEY_PASSWORT
